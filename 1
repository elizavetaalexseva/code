typedef complex T;

class complex
{
	double real, img;
public:
	complex(double x = 0, double y = 0) { real = x; img = y; };
	double get_re() { return real; }
	double get_im() { return img; }
	void operator= (complex& a) {
		real = a.get_re();
		img = a.get_im();
	}
	bool operator== (complex& a) {
		if ((real == a.get_re()) && (img == a.get_im())) {
			return true;
		}
		else {
			return false;
		}
	}
	friend istream& operator>>(istream& in, complex& comp);
	friend ostream& operator<<(ostream& out, const complex& comp);
};

istream& operator>>(istream& in, complex& comp) {
	in >> comp.real >> comp.img;
	return in;
}
ostream& operator<<(ostream& out, const complex& comp) {
	out << comp.real;
	if (comp.img >= 0)
		cout << '+';
	cout << comp.img << "*i";
	return cout;
}


template <class T>
class ar {
	T* data;
	int size;
	int index;
public:
	ar(int& size);
	~ar();
	int get_s() { return size; };
	void new_s(int s) { size = s; };
	void new_i(int i) { index = i; };
	T get_d(int& index) { return data[index]; };
	int add(T&);
	void input();
	void output();
	void del(int&);
	bool is(ar&, int&);
	bool isin(T);
	void intersec(ar&, ar&);
	void un(ar&, ar&);
};


bool ar <T>::isin(T n) {
	for (int i = 0; i < size; i++) {
		if (data[i] == n) {
			return true;
		}
	}
	return false;
}

ar<T>::ar(int& s) {
	data = new T[s];
	if (data == NULL) {
		cerr << "Недостаточно памяти" << endl;
		exit(1);
	}
	size = s;
	index = 0;
}

ar<T>::~ar() {
	delete[] data;
	size = 0;
	index = 0;
}

int ar<T>::add(T& value) {
	if (index == size) return(-1);
	else {
		data[index] = value;
		index++;
		return(0);
	}
}

void ar<T>::input() {
	for (int i = 0; i < size; i++) {
		T v;
		cin >> v;
		add(v);
	}
}

void ar<T>::output() {
	for (int i = 0; i < size; i++) {
		cout << data[i] << endl;
	}
}

void ar<T>::del(int& index) {
	for (int i = index - 1; i < size - 1; i++) {
		data[i] = data[i + 1];
	}
	size--;
	index--;
}

bool ar<T>::is(ar& s2, int& index) {
	int s = s2.get_s();
	for (int j = 0; j < s; j++) {
		T r = s2.get_d(j);
		if (data[index] == r) {
			return(true);
		}
	}
	return (false);
}

void ar<T>::intersec(ar& s2, ar& s3) {
	int i;
	int k = 0;
	for (i = 0; i < size; i++) {
		if (is(s2, i)) {
			s3.add(data[i]);
			k++;
		}
	}
	s3.new_s(k);
}

void ar<T>::un(ar& s2, ar& s4) {
	int size2 = s2.get_s();
	int i, j;
	int k = 0;
	for (i = 0; i < size; i++) {
		if (!is(s2, i)) {
			s4.add(data[i]);
			k++;
		}
	}
	for (j = 0; j < size2; j++) {
		T d = s2.get_d(j);
		s4.add(d);
		k++;
	}
	s4.new_s(k);
}



